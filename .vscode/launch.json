{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "debug server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tigerbeetle",
            "args": [ "start", "--addresses=127.0.0.1", "./tb.debug" ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "preLaunchTask": "build server",
        },
        {
            "name": "debug amqp",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tigerbeetle",
            "args": [ "amqp", "--addresses=3000" ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "preLaunchTask": "build server",
        },
        {
            "name": "debug vopr",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/zig-out/bin/vopr",
            "args": ["--lite", "11859786447386793385" ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "preLaunchTask": "build vopr",
        },
        {
            "name": "debug test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/zig-out/bin/test",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "preLaunchTask": "build test",
        },
    ]
}
