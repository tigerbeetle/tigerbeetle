{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "format debug server",
            "type": "shell",
            "command": "${workspaceFolder}/.vscode/format_debug_server.sh",
            "args": [],
            "problemMatcher": [],
            "group": "build",
        },
        {
            "label": "build server",
            "type": "shell",
            "command": "${workspaceFolder}/zig/zig",
            "args": [ "build", "install" ],
            "problemMatcher": [],
            "group": "build",
        },
        {
            "label": "build vopr",
            "type": "shell",
            "command": "${workspaceFolder}/zig/zig",
            "args": [ "build", "vopr:build", "--", "1" ],
            "problemMatcher": [],
            "group": "build",
        },
        {
            "label": "build fuzz",
            "type": "shell",
            "command": "${workspaceFolder}/zig/zig",
            "args": [ "build", "fuzz:build", "--", "1" ],
            "problemMatcher": [],
            "group": "build",
        },
        {
            "label": "build test",
            "type": "shell",
            "command": "${workspaceFolder}/zig/zig",
            "args": [ "build", "test:unit:build", "--", "\"create_transfers/lookup_transfers\"" ],
            "problemMatcher": [],
            "group": "build",
        },
        {
            "label": "build scripts",
            "type": "shell",
            "command": "${workspaceFolder}/zig/zig",
            "args": [ "build", "scripts:build" ],
            "problemMatcher": [],
            "group": "build",
        },
   ]
}
